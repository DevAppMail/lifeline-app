# ── LifeLine App — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.
#
# Deploy order: 1) Supabase 2) lifeline-admin 3) lifeline-pro 4) backend (BFF) 5) lifeline-app

# Supabase (public anon key — safe for frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin API (used by vite proxy in dev; in production the BFF handles this)
VITE_API_URL=

# MSG91 SMS notifications
VITE_MSG91_TEMPLATE_ID=

# Razorpay payment integration (public key — safe for frontend)
VITE_RAZORPAY_KEY_ID=

# PostHog analytics
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.posthog.com

# App BFF (backend federation layer) — server-side only, not exposed to frontend
BFF_PORT=3001
ADMIN_API_URL=http://localhost:3000
ADMIN_BFF_API_KEY=change-this-in-production
JWT_SECRET=generate-a-strong-random-secret-here
JWT_EXPIRES_IN=24h
