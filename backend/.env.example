# ── BFF Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.
#
# Deploy order: 1) Supabase 2) lifeline-admin 3) lifeline-pro 4) BFF 5) lifeline-app

# Server
BFF_PORT=3001
NODE_ENV=development

# Supabase (app instance — used for auth token verification)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin backend
ADMIN_API_URL=http://localhost:3000
ADMIN_BFF_API_KEY=generate-a-strong-random-secret

# Pro Supabase (service role key — read/write pro database)
PRO_SUPABASE_URL=https://your-pro-project.supabase.co
PRO_SUPABASE_SERVICE_KEY=your-service-role-key

# JWT for federated identity tokens
JWT_SECRET=generate-a-strong-random-secret
JWT_EXPIRES_IN=24h

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:5173
